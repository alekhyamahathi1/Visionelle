{
  "manifest_version": 3,
  "name": "Jam - Safe Browsing for Kids",
  "version": "1.0.0",
  "description": "Makes the internet a safer place for kids with AI-powered content filtering",
  "permissions": ["activeTab", "storage", "tabs", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
