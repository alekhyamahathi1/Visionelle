{
  "manifest_version": 3,
  "name": "Jam - Safe Browsing for Kids",
  "version": "1.2.0",
  "description": "AI-powered content filtering with unsupervised learning for safe browsing",
  "permissions": ["activeTab", "storage", "tabs", "scripting"],
  "host_permissions": ["http://localhost:*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dataset.js", "expanded_dataset.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png", 
    "128": "icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["dataset.js", "expanded_dataset.js", "*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
